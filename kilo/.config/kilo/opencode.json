{
  "$schema": "https://opencode.ai/config.json",
  "small_model": "deepseek/deepseek-v4-flash",
  "permission": {
    "*": "allow",
    "bash": {
      "*": "ask",
      "grep *": "allow",
      "ls *": "allow"
    },
    "edit": "ask",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    }
  },
  "experimental": {
    "openTelemetry": false
  },
  "lsp": true
}
