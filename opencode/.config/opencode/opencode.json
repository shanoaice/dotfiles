{
  "$schema": "https://opencode.ai/config.json",
  "small_model": "deepseek/deepseek-v4-flash",
  "agent": {
    "orchestrator": {
      "hidden": true
    }
  },
  "permission": {
    "*": "allow",
    "bash": {
      "*": "ask",
      "grep *": "allow",
      "ls *": "allow"
    },
    "edit": "ask",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    }
  },
  "experimental": {
    "codebase_search": true,
    "openTelemetry": true
  },
  "plugin": [
    "oh-my-openagent@latest"
  ]
}
